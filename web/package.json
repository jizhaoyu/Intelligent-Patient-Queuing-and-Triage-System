{
  "name": "triage-queue-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --mode admin",
    "dev:workstation": "vite --mode workstation",
    "dev:screen": "vite --mode screen",
    "dev:kiosk": "vite --mode kiosk",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:admin": "npm run typecheck && vite build --mode admin",
    "build:workstation": "npm run typecheck && vite build --mode workstation",
    "build:screen": "npm run typecheck && vite build --mode screen",
    "build:kiosk": "npm run typecheck && vite build --mode kiosk",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.8.4",
    "element-plus": "^2.9.7",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vue-tsc": "^2.2.8"
  }
}
